def _read_table(path: str, *, dtype: dict | None = None) -> pd.DataFrame:
    if not os.path.exists(path):
        raise FileNotFoundError(f"File not found: {path}")

    ext = os.path.splitext(path)[1].lower()
    if ext in [".tsv", ".tab"]:
        return pd.read_csv(path, sep="\t", dtype=dtype, low_memory=False)
    if ext in [".csv"]:
        return pd.read_csv(path, dtype=dtype, low_memory=False)

    return pd.read_csv(path, sep=None, engine="python", dtype=dtype, low_memory=False)


def _standardize_columns(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()
    df.columns = [c.strip().lower() for c in df.columns]
    return df


def safe_unique_count(series: Optional[pd.Series]) -> int:
    if series is None or len(series) == 0:
        return 0
    return int(series.dropna().nunique())


def benjamini_hochberg(pvals: np.ndarray) -> np.ndarray:
    p = np.asarray(pvals, dtype=float)
    n = p.size
    order = np.argsort(p)
    ranked = p[order]
    adj = np.empty_like(ranked)

    cummin = 1.0
    for i in range(n - 1, -1, -1):
        rank = i + 1
        val = ranked[i] * n / rank
        if val < cummin:
            cummin = val
        adj[i] = min(cummin, 1.0)

    out = np.empty_like(adj)
    out[order] = adj
    return out


