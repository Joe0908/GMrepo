def sidebar(paths: DataPaths) -> str:
    st.sidebar.title("Navigation")
    page = st.sidebar.radio(
        "Go to",
        ["Home / Overview", "Disease & Taxon Atlas", "Pairwise Group Comparison"],
        index=0,
    )

    st.sidebar.divider()
    st.sidebar.caption("Data files")
    st.sidebar.write(f"sample_metadata: {paths.sample_metadata}")
    st.sidebar.write(f"abundance: {paths.abundance}")
    st.sidebar.write(f"taxonomy: {paths.taxonomy}")

    st.sidebar.divider()
    st.sidebar.caption("Tips")
    st.sidebar.write("Caching is enabled for loading and joins for faster page switching.")
    st.sidebar.write("If results look empty, verify: abundance.accession_id == sample_metadata.run_id.")

    # Optional: allow clearing cache in UI
    if st.sidebar.button("Clear cache"):
        st.cache_data.clear()
        st.sidebar.success("Cache cleared. Rerun actions to rebuild.")

    return page


def main() -> None:
    st.set_page_config(page_title=APP_TITLE, layout="wide")
    page = sidebar(DATA_PATHS)

    try:
        samples, abund, taxa = load_data(DATA_PATHS)
    except Exception as e:
        st.error(f"Failed to load data: {e}")
        return

    if "run_id" not in samples.columns:
        st.warning("sample_metadata missing 'run_id'. If your key differs, update join_abundance_with_samples.")
    for c in ["accession_id", "ncbi_taxon_id", "relative_abundance"]:
        if c not in abund.columns:
            st.warning(f"abundance missing '{c}'.")

    if page == "Home / Overview":
        page_home(samples, abund, taxa)
    
    elif page == "Disease & Taxon Atlas":
        page_disease_taxon_atlas(samples, abund, taxa)
    elif page == "Pairwise Group Comparison":
        page_pairwise_group_comparison(samples, abund, taxa)



if __name__ == "__main__":
    main()
