    st.sidebar.title("Navigation")
    page = st.sidebar.radio(
        "Go to",
        [
            "Home / Overview",
            "Disease & Taxon Atlas",
            "Taxon Across Diseases",
            "Pairwise Group Comparison",
        ],
        index=0,
        key="nav_page",
    )

    st.sidebar.divider()
    st.sidebar.caption("Data files")
    st.sidebar.write(f"sample_metadata: {paths.sample_metadata}")
    st.sidebar.write(f"abundance: {paths.abundance}")
    st.sidebar.write(f"taxonomy: {paths.taxonomy}")

    st.sidebar.divider()
    st.sidebar.caption("Tips")
    st.sidebar.write("Caching is enabled for loading and filtered joins for faster page switching.")
    st.sidebar.write("If results look empty, verify that abundance.accession_id matches sample_metadata.run_id.")
    st.sidebar.write("The Taxon Across Diseases page requires a 'Healthy' label in your group column.")

    if st.sidebar.button("Clear cache", key="clear_cache"):
        st.cache_data.clear()
        st.sidebar.success("Cache cleared. Please rerun actions to rebuild.")

    return page


def main() -> None:
    st.set_page_config(page_title=APP_TITLE, layout="wide")
    page = sidebar(DATA_PATHS)

    try:
        samples, abund, taxa = load_data(DATA_PATHS)
    except Exception as e:
        st.error(f"Failed to load data: {e}")
        return

    if "run_id" not in samples.columns:
        st.warning("sample_metadata missing 'run_id'. If your key differs, update the join keys accordingly.")
    for c in ["accession_id", "ncbi_taxon_id", "relative_abundance"]:
        if c not in abund.columns:
            st.warning(f"abundance missing '{c}'.")

    if page == "Home / Overview":
        page_home(samples, abund, taxa)
    elif page == "Disease & Taxon Atlas":
        page_disease_taxon_atlas(samples, abund, taxa)
    elif page == "Taxon Across Diseases":
        page_taxon_across_diseases(samples, abund, taxa)
    elif page == "Pairwise Group Comparison":
        page_pairwise_group_comparison(samples, abund, taxa)


if __name__ == "__main__":
    main()
