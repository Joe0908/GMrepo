            comp_view.sort_values("abundance").tail(50),
            x="taxon",
            y="abundance",
            hover_data=["prevalence"],
            title=f"{dis}: abundance ({agg2}), showing up to 50 taxa",
        )
        figb.update_layout(xaxis_title="Taxon", yaxis_title="Abundance", xaxis={"categoryorder": "total ascending"})
        st.plotly_chart(figb, use_container_width=True)

        figp = px.bar(
            comp_view.sort_values("prevalence").tail(50),
            x="taxon",
            y="prevalence",
            title=f"{dis}: prevalence, showing up to 50 taxa",
        )
