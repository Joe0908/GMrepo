@st.cache_data(show_spinner=False)
def load_data(paths: DataPaths) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    sample_types = {
        "country": "category",
        "phenotype": "category",
        "disease": "category",
        "experiment_type": "category",
        "recent_antibiotics_use": "category",
    }
    samples = _standardize_columns(_read_table(paths.sample_metadata, dtype=sample_types))

    abund_types = {
        "accession_id": "string",
        "ncbi_taxon_id": "string",
        "taxon_rank_level": "category",
        "relative_abundance": "float32",
    }
    abund = _standardize_columns(_read_table(paths.abundance, dtype=abund_types))

    taxa_types = {
        "ncbi_taxon_id": "string",
        "scientific_name": "string",
        "taxon_rank_level": "category",
    }
    taxa = _standardize_columns(_read_table(paths.taxonomy, dtype=taxa_types))

    if "relative_abundance" in abund.columns and not pd.api.types.is_numeric_dtype(abund["relative_abundance"]):
        abund["relative_abundance"] = pd.to_numeric(abund["relative_abundance"], errors="coerce")

    return samples, abund, taxa


# ----------------------------
# Filter-first join (saves memory/time)
# ----------------------------

def collect_sample_filters(samples: pd.DataFrame) -> dict:
    filters: dict = {}
    with st.expander("Optional filters", expanded=False):
        for col, label in [
            ("experiment_type", "Experiment type"),
            ("country", "Country"),
            ("recent_antibiotics_use", "Recent antibiotics use"),
        ]:
            if col in samples.columns and samples[col].notna().any():
                options = ["All"] + sorted(samples[col].dropna().astype(str).unique().tolist())
                choice = st.selectbox(label, options, key=f"flt_{col}")
                filters[col] = choice
            else:
                st.caption(f"No {col} column available (or all empty).")
    return filters


@st.cache_data(show_spinner=False)
def get_filtered_abundance(
    samples: pd.DataFrame,
    abund: pd.DataFrame,
    taxa: pd.DataFrame,
    filters: dict,
) -> pd.DataFrame:
    s_filtered = samples

    for col, value in (filters or {}).items():
        if value != "All" and col in s_filtered.columns:
            s_filtered = s_filtered[s_filtered[col].astype(str) == str(value)]

    if "run_id" not in s_filtered.columns:
        raise ValueError("sample_metadata must contain 'run_id'")

    valid_ids = pd.Index(s_filtered["run_id"].astype(str).unique())
    if valid_ids.empty:
        return pd.DataFrame()

    if "accession_id" not in abund.columns:
        raise ValueError("abundance must contain 'accession_id'")

    a_filtered = abund[abund["accession_id"].astype(str).isin(valid_ids)].copy()
    if a_filtered.empty:
        return pd.DataFrame()

    taxa2 = taxa.copy()
    if "scientific_name" not in taxa2.columns:
        for alt in ["name", "taxon_name"]:
            if alt in taxa2.columns:
                taxa2 = taxa2.rename(columns={alt: "scientific_name"})
                break
    if "scientific_name" not in taxa2.columns:
        taxa2["scientific_name"] = "Unknown"

    t_subset_cols = ["ncbi_taxon_id", "scientific_name"]
    if "taxon_rank_level" in taxa2.columns:
        t_subset_cols.append("taxon_rank_level")

    t_subset = taxa2[t_subset_cols].drop_duplicates()
    merged = a_filtered.merge(t_subset, on="ncbi_taxon_id", how="left")

    if "phenotype" in s_filtered.columns:
        group_col = "phenotype"
    elif "disease" in s_filtered.columns:
        group_col = "disease"
    else:
        raise ValueError("sample_metadata must contain 'phenotype' or 'disease'")

    group_info = s_filtered[["run_id", group_col]].copy()
    final = merged.merge(group_info, left_on="accession_id", right_on="run_id", how="inner")
    return final


def get_group_col(joined: pd.DataFrame) -> Optional[str]:
    if "phenotype" in joined.columns:
        return "phenotype"
    if "disease" in joined.columns:
        return "disease"
    return None


def filter_rank_level(
    joined: pd.DataFrame,
    *,
    key: str = "rank_level",
) -> Tuple[pd.DataFrame, Optional[str], Optional[str]]:
    if "taxon_rank_level" in joined.columns and joined["taxon_rank_level"].notna().any():
        rank_levels = sorted(joined["taxon_rank_level"].dropna().astype(str).unique().tolist())
        rank_level = st.selectbox("Taxon rank level", rank_levels, index=0, key=key)
        return joined[joined["taxon_rank_level"].astype(str) == str(rank_level)].copy(), str(rank_level), None
    return joined.copy(), None, "No taxon_rank_level found. Using all rows."


# ----------------------------
# Pairwise group comparison (vectorized)
# ----------------------------

@st.cache_data(show_spinner=False)
def compute_group_comparison_vectorized(
    df: pd.DataFrame,
    group_col: str,
    group_a: str,
    group_b: str,
    abundance_col: str = "relative_abundance",
    taxon_col: str = "scientific_name",
    min_prevalence: float = 0.1,
) -> pd.DataFrame:
    if df is None or df.empty:
        return pd.DataFrame(
            columns=[
                taxon_col,
                f"mean_{group_a}",
                f"mean_{group_b}",
                "log2fc",
                "pvalue",
                "qvalue",
                "n_a",
                "n_b",
            ]
        )

    for c in ["accession_id", group_col, taxon_col, abundance_col]:
        if c not in df.columns:
            raise ValueError(f"df missing required column: {c}")

    sub = df[df[group_col].astype(str).isin([str(group_a), str(group_b)])].copy()
    if sub.empty:
        return pd.DataFrame(
            columns=[
                taxon_col,
                f"mean_{group_a}",
                f"mean_{group_b}",
                "log2fc",
                "pvalue",
                "qvalue",
                "n_a",
                "n_b",
            ]
        )

    if not pd.api.types.is_numeric_dtype(sub[abundance_col]):
        sub[abundance_col] = pd.to_numeric(sub[abundance_col], errors="coerce")
    sub = sub.dropna(subset=[abundance_col, taxon_col, group_col, "accession_id"])

    pivot = sub.pivot_table(
        index="accession_id",
        columns=taxon_col,
        values=abundance_col,
        fill_value=0.0,
        aggfunc="mean",
    )

    labels = sub.drop_duplicates("accession_id").set_index("accession_id")[group_col].astype(str)
    current = labels.reindex(pivot.index).astype(str).to_numpy()

    mask_a = current == str(group_a)
    mask_b = current == str(group_b)

    n_a = int(mask_a.sum())
    n_b = int(mask_b.sum())
    if n_a == 0 or n_b == 0:
        return pd.DataFrame(
            columns=[
                taxon_col,
                f"mean_{group_a}",
                f"mean_{group_b}",
                "log2fc",
                "pvalue",
                "qvalue",
                "n_a",
                "n_b",
            ]
        )

    X = pivot.to_numpy(dtype=float, copy=False)
    Xa = X[mask_a]
    Xb = X[mask_b]

    mean_a = Xa.mean(axis=0)
    mean_b = Xb.mean(axis=0)

    prev_a = (Xa > 0).mean(axis=0)
    prev_b = (Xb > 0).mean(axis=0)
    keep = (prev_a >= float(min_prevalence)) | (prev_b >= float(min_prevalence))

    if not keep.any():
        return pd.DataFrame(
            columns=[
                taxon_col,
                f"mean_{group_a}",
                f"mean_{group_b}",
                "log2fc",
                "pvalue",
                "qvalue",
                "n_a",
                "n_b",
            ]
        )

    cols = pivot.columns.to_numpy()
    cols_keep = cols[keep]
    mean_a = mean_a[keep]
    mean_b = mean_b[keep]
    Xa = Xa[:, keep]
    Xb = Xb[:, keep]

    eps = 1e-6
    log2fc = np.log2((mean_b + eps) / (mean_a + eps))

    try:
        _stat, pvals = mannwhitneyu(Xa, Xb, axis=0, alternative="two-sided")
    except Exception:
        pvals = np.full(mean_a.shape[0], np.nan, dtype=float)

    out = pd.DataFrame(
        {
            taxon_col: cols_keep.astype(str),
            f"mean_{group_a}": mean_a.astype(float),
            f"mean_{group_b}": mean_b.astype(float),
            "log2fc": log2fc.astype(float),
            "pvalue": pvals.astype(float),
            "n_a": n_a,
            "n_b": n_b,
        }
    )

    out["qvalue"] = benjamini_hochberg(out["pvalue"].fillna(1.0).to_numpy(dtype=float))
    return out.sort_values(["qvalue", "pvalue"], ascending=[True, True], na_position="last").reset_index(drop=True)


