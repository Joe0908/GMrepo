        if "recent_antibiotics_use" in joined.columns and joined["recent_antibiotics_use"].notna().any():
            abx = st.selectbox("Recent antibiotics use", ["All", "Y", "N"])
            if abx != "All":
                joined = joined[joined["recent_antibiotics_use"] == abx]
