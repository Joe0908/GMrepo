def page_pairwise_group_comparison(
    samples: pd.DataFrame,
    abund: pd.DataFrame,
    taxa: pd.DataFrame,
) -> None:

    st.header("Pairwise Group Comparison")

    st.markdown(
        """
Compare two groups (for example Healthy(control) vs a disease)
and identify taxa that differ.

Workflow:
1) Select two groups and taxonomic rank.
2) Adjust optional analysis settings.
3) Click "Run comparison".
        """
    )

    st.divider()

    # ---------- rank options ----------
    if "taxon_rank_level" in taxa.columns and taxa["taxon_rank_level"].notna().any():
        rank_levels_all = sorted(
            taxa["taxon_rank_level"].dropna().astype(str).unique().tolist()
        )
    else:
        rank_levels_all = []

    # ---------- group options ----------
    if "phenotype" in samples.columns and samples["phenotype"].notna().any():
        group_options_all = sorted(
            samples["phenotype"].dropna().astype(str).unique().tolist()
        )
    elif "disease" in samples.columns and samples["disease"].notna().any():
        group_options_all = sorted(
            samples["disease"].dropna().astype(str).unique().tolist()
        )
    else:
        group_options_all = []

    if len(group_options_all) < 2:
        st.warning("Not enough groups available for comparison.")
        return

    # ======================================================
    # FORM
    # ======================================================
    with st.form("pairwise_form"):

        st.subheader("Selections")

        c1, c2, c3 = st.columns([2, 2, 1])

        # ---- Group A ----
        with c1:
            group_a = st.selectbox(
                "Group A",
                group_options_all,
                index=None,
                placeholder="Type e.g. 'Healthy'",
                key="pair_group_a",
            )

        # ---- Group B (independent selection) ----
        with c2:
            group_b = st.selectbox(
                "Group B",
                group_options_all,
                index=None,
                placeholder="Type comparison group",
                key="pair_group_b",
            )

        # ---- Rank ----
        with c3:
            if rank_levels_all:
                rank_level = st.selectbox(
                    "Taxon rank",
                    rank_levels_all,
                    key="pair_rank",
                )
            else:
                rank_level = None

        # ================= Advanced =================
        with st.expander("Advanced settings", expanded=False):

            c1, c2, c3 = st.columns(3)

            with c1:
                min_prev = st.slider(
                    "Min prevalence",
                    0.0, 1.0, 0.1, 0.05,
                    key="pair_min_prev",
                )

            with c2:
                q_cut = st.slider(
                    "q-value cutoff",
                    0.0, 0.25, 0.05, 0.01,
                    key="pair_q_cut",
                )

            with c3:
                top_k = st.slider(
                    "Top taxa shown",
                    5, 50, 20, 5,
                    key="pair_top_k",
                )

        # ---------- Optional cohort filters ----------
        filters = collect_sample_filters(
            samples,
            expanded=False,
            key_prefix="pair_flt",
        )

        st.divider()
        run = st.form_submit_button(
            "Run pairwise comparison",
            type="primary",
        )

    # ======================================================
    # VALIDATION
    # ======================================================
    if not run:
        st.info(
            'Select Group A and Group B, then click "Run pairwise comparison".'
        )
        return

    if group_a is None or group_b is None:
        st.warning("Please select BOTH Group A and Group B.")
        return

    if str(group_a) == str(group_b):
        st.warning("Group A and Group B must be different.")
        return

    # ======================================================
    # EXPENSIVE COMPUTATION
    # ======================================================
    joined = get_filtered_abundance(samples, abund, taxa, filters)

    if joined.empty:
        st.warning("No rows after filtering.")
        return

    group_col = get_group_col(joined)
    if group_col is None:
        st.error("Could not determine grouping column.")
        return

    if rank_level is not None and "taxon_rank_level" in joined.columns:
        joined = joined[
            joined["taxon_rank_level"].astype(str) == str(rank_level)
        ].copy()

    res = compute_group_comparison_vectorized(
        df=joined,
        group_col=group_col,
        group_a=group_a,
        group_b=group_b,
        abundance_col="relative_abundance",
        taxon_col="scientific_name",
        min_prevalence=float(min_prev),
    )

    if res.empty:
        st.warning("No taxa passed filters.")
        return

    # ======================================================
    # RESULT PROCESSING
    # ======================================================
    res2 = res.copy()
    res2["abs_log2fc"] = res2["log2fc"].abs()

    sig = res2[
        pd.to_numeric(res2["qvalue"], errors="coerce") <= q_cut
    ]

    show = (
        sig.sort_values("abs_log2fc", ascending=False).head(top_k)
        if len(sig) > 0
        else res2.sort_values("abs_log2fc", ascending=False).head(top_k)
    ).sort_values("log2fc")

    # ======================================================
    # OUTPUT
    # ======================================================
    st.subheader("Results table")

    res_show = res.copy()
    res_show["pvalue"] = format_scientific(res_show["pvalue"])
    res_show["qvalue"] = format_scientific(res_show["qvalue"])

    st.dataframe(res_show, use_container_width=True)

    st.download_button(
        "Download results CSV",
        data=res.to_csv(index=False).encode("utf-8"),
        file_name=f"{group_a}_vs_{group_b}.csv".replace(" ", "_"),
        mime="text/csv",
    )

    # ---------- Bar plot ----------
    st.subheader("Top changing taxa")

    fig = px.bar(
        show,
        x="scientific_name",
        y="log2fc",
        title=f"log2 Fold Change: {group_b} vs {group_a}",
    )
    st.plotly_chart(fig, use_container_width=True)

    # ---------- Volcano ----------
    st.subheader("Volcano plot")

    volc = res2.copy()
    qv = pd.to_numeric(volc["qvalue"], errors="coerce").fillna(1.0)
    volc["neglog10_q"] = -np.log10(np.clip(qv, 1e-300, 1.0))

    fig2 = px.scatter(
        volc,
        x="log2fc",
        y="neglog10_q",
        hover_data=["scientific_name", "pvalue", "qvalue"],
    )

    st.plotly_chart(fig2, use_container_width=True)


