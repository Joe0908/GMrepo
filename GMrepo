@st.cache_data(show_spinner=False)
def compute_group_comparison(
    joined: pd.DataFrame,
    group_col: str,
    group_a: str,
    group_b: str,
    taxon_name_col: str = "scientific_name",
    abundance_col: str = "relative_abundance",
    min_prevalence: float = 0.1,
) -> pd.DataFrame:
    df = joined.copy()

    for col in [group_col, taxon_name_col, abundance_col]:
        if col not in df.columns:
            raise ValueError(f"joined table missing required column: {col}")

    df = df[df[group_col].astype(str).isin([str(group_a), str(group_b)])].copy()
    df[abundance_col] = pd.to_numeric(df[abundance_col], errors="coerce")
    df = df.dropna(subset=[abundance_col, taxon_name_col])

    prevalence = (
        df.assign(present=df[abundance_col] > 0)
        .groupby([taxon_name_col, group_col])["present"]
        .mean()
        .unstack(group_col)
        .fillna(0.0)
    )
    prevalence = prevalence.loc[:, ~prevalence.columns.duplicated()]

    vec_a = prevalence[group_a] if group_a in prevalence.columns else pd.Series(0.0, index=prevalence.index)
    vec_b = prevalence[group_b] if group_b in prevalence.columns else pd.Series(0.0, index=prevalence.index)

    mask = (vec_a >= float(min_prevalence)) | (vec_b >= float(min_prevalence))
    keep_taxa = prevalence.index[mask].tolist()
    df = df[df[taxon_name_col].isin(keep_taxa)].copy()

    rows = []
    for taxon, sub in df.groupby(taxon_name_col, sort=False):
        a = sub.loc[sub[group_col].astype(str) == str(group_a), abundance_col].to_numpy()
        b = sub.loc[sub[group_col].astype(str) == str(group_b), abundance_col].to_numpy()

        mean_a = float(np.nanmean(a)) if a.size else np.nan
        mean_b = float(np.nanmean(b)) if b.size else np.nan

        eps = 1e-6
        log2fc = float(np.log2((mean_b + eps) / (mean_a + eps))) if np.isfinite(mean_a) and np.isfinite(mean_b) else np.nan

        p = np.nan
        if a.size > 1 and b.size > 1:
            try:
                p = float(mannwhitneyu(a, b, alternative="two-sided").pvalue)
            except Exception:
                p = np.nan

        rows.append((str(taxon), mean_a, mean_b, log2fc, p, int(a.size), int(b.size)))

    out = pd.DataFrame(
        rows,
        columns=[taxon_name_col, f"mean_{group_a}", f"mean_{group_b}", "log2fc", "pvalue", "n_a", "n_b"],
    )

    if out.empty:
        out["qvalue"] = []
        return out

    out["qvalue"] = benjamini_hochberg(out["pvalue"].fillna(1.0).values)
    out = out.sort_values(["qvalue", "pvalue"], ascending=[True, True], na_position="last").reset_index(drop=True)
    return out


@st.cache_data(show_spinner=False)
def compute_group_comparison_vectorized(
    df: pd.DataFrame,
    group_col: str,
    group_a: str,
    group_b: str,
    abundance_col: str = "relative_abundance",
    taxon_col: str = "scientific_name",
    min_prevalence: float = 0.1,
) -> pd.DataFrame:
    """Vectorized pairwise comparison across taxa.

    Steps:
      1) pivot to sample x taxon matrix
      2) compute mean + prevalence masks vectorized
      3) Mann-Whitney U across columns (axis=0)
    """
    if df is None or df.empty:
        return pd.DataFrame(columns=[taxon_col, f"mean_{group_a}", f"mean_{group_b}", "log2fc", "pvalue", "qvalue", "n_a", "n_b"])

    for c in ["accession_id", group_col, taxon_col, abundance_col]:
        if c not in df.columns:
            raise ValueError(f"df missing required column: {c}")

    sub = df[df[group_col].astype(str).isin([str(group_a), str(group_b)])].copy()
    if sub.empty:
        return pd.DataFrame(columns=[taxon_col, f"mean_{group_a}", f"mean_{group_b}", "log2fc", "pvalue", "qvalue", "n_a", "n_b"])

    # Ensure numeric abundances for pivot computations
    if not pd.api.types.is_numeric_dtype(sub[abundance_col]):
        sub[abundance_col] = pd.to_numeric(sub[abundance_col], errors="coerce")
    sub = sub.dropna(subset=[abundance_col, taxon_col, group_col, "accession_id"])

    pivot = sub.pivot_table(
        index="accession_id",
        columns=taxon_col,
        values=abundance_col,
        fill_value=0.0,
        aggfunc="mean",
    )

    # group labels per sample (one label per accession_id)
    labels = sub.drop_duplicates("accession_id").set_index("accession_id")[group_col].astype(str)
    current = labels.reindex(pivot.index).astype(str).to_numpy()

    mask_a = current == str(group_a)
    mask_b = current == str(group_b)

    n_a = int(mask_a.sum())
    n_b = int(mask_b.sum())
    if n_a == 0 or n_b == 0:
        return pd.DataFrame(columns=[taxon_col, f"mean_{group_a}", f"mean_{group_b}", "log2fc", "pvalue", "qvalue", "n_a", "n_b"])

    X = pivot.to_numpy(dtype=float, copy=False)
    Xa = X[mask_a]
    Xb = X[mask_b]

    mean_a = Xa.mean(axis=0)
    mean_b = Xb.mean(axis=0)

    prev_a = (Xa > 0).mean(axis=0)
    prev_b = (Xb > 0).mean(axis=0)
    keep = (prev_a >= float(min_prevalence)) | (prev_b >= float(min_prevalence))

    if not keep.any():
        return pd.DataFrame(columns=[taxon_col, f"mean_{group_a}", f"mean_{group_b}", "log2fc", "pvalue", "qvalue", "n_a", "n_b"])

    cols = pivot.columns.to_numpy()
    cols_keep = cols[keep]
    mean_a = mean_a[keep]
    mean_b = mean_b[keep]
    Xa = Xa[:, keep]
    Xb = Xb[:, keep]

    eps = 1e-6
    log2fc = np.log2((mean_b + eps) / (mean_a + eps))

    from scipy.stats import mannwhitneyu
    try:
        _stat, pvals = mannwhitneyu(Xa, Xb, axis=0, alternative="two-sided")
    except Exception:
        pvals = np.full(mean_a.shape[0], np.nan, dtype=float)

    out = pd.DataFrame({
        taxon_col: cols_keep.astype(str),
        f"mean_{group_a}": mean_a.astype(float),
        f"mean_{group_b}": mean_b.astype(float),
        "log2fc": log2fc.astype(float),
        "pvalue": pvals.astype(float),
        "n_a": n_a,
        "n_b": n_b,
    })

    out["qvalue"] = benjamini_hochberg(out["pvalue"].fillna(1.0).to_numpy(dtype=float))
    return out.sort_values(["qvalue", "pvalue"], ascending=[True, True], na_position="last").reset_index(drop=True)


