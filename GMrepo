@st.cache_data(show_spinner=False)
def disease_composition_table(
    joined: pd.DataFrame,
    group_col: str,
    disease: str,
    rank_level: Optional[str] = None,
    taxon_col: str = "scientific_name",
    abundance_col: str = "relative_abundance",
    top_n: int = 30,
    agg: str = "mean",
    drop_unknown: bool = True,
) -> pd.DataFrame:
    df = joined.copy()

    for c in [group_col, taxon_col, abundance_col]:
        if c not in df.columns:
            raise ValueError(f"joined missing column: {c}")

    if rank_level is not None and "taxon_rank_level" in df.columns:
        df = df[df["taxon_rank_level"].astype(str) == str(rank_level)]

    df[group_col] = df[group_col].astype(str)
    df = df[df[group_col] == str(disease)].copy()

    df[abundance_col] = pd.to_numeric(df[abundance_col], errors="coerce")
    df = df.dropna(subset=[taxon_col, abundance_col])

    if drop_unknown:
        df = df[~df[taxon_col].astype(str).isin(["Unknown", "unclassified"])]

    if df.empty:
        return pd.DataFrame(columns=["taxon", "abundance", "prevalence", "n_samples"])

    sample_col = "accession_id" if "accession_id" in df.columns else ("run_id" if "run_id" in df.columns else None)
    if sample_col is None:
        raise ValueError("No sample id column found (accession_id or run_id)")

    pivot = df.pivot_table(index=sample_col, columns=taxon_col, values=abundance_col, fill_value=0.0)
    abund = pivot.median(axis=0) if agg == "median" else pivot.mean(axis=0)
    prev = (pivot > 0).mean(axis=0)
    n_samples = int(pivot.shape[0])

    out = pd.DataFrame(
        {
            "taxon": abund.index.astype(str),
            "abundance": abund.values.astype(float),
            "prevalence": prev.values.astype(float),
            "n_samples": n_samples,
        }
    )
    out = (
        out.sort_values(["abundance", "prevalence"], ascending=[False, False])
        .head(int(top_n))
        .reset_index(drop=True)
    )
    return out


# ----------------------------
# Taxon across diseases (vs Healthy)
# ----------------------------

@st.cache_data(show_spinner=False)
def taxon_vs_healthy_one_taxon(
    joined: pd.DataFrame,
    group_col: str,
    taxon: str,
    *,
    rank_level: Optional[str] = None,
    healthy_label: str = "Healthy",
    taxon_col: str = "scientific_name",
    abundance_col: str = "relative_abundance",
    min_n_per_group: int = 8,
    min_prevalence: float = 0.1,
    drop_unknown: bool = True,
) -> pd.DataFrame:
    """
    Compute disease-vs-Healthy stats for ONE selected taxon only.
    This avoids building a huge sample x taxa matrix and is much faster.
    Output: one row per disease for this taxon.
    """

    df = joined.copy()

    # validate
    for c in ["accession_id", group_col, taxon_col, abundance_col]:
        if c not in df.columns:
            raise ValueError(f"joined missing column: {c}")

    # rank filter
    if rank_level is not None and "taxon_rank_level" in df.columns:
        df = df[df["taxon_rank_level"].astype(str) == str(rank_level)]

    df[group_col] = df[group_col].astype(str)
    df[taxon_col] = df[taxon_col].astype(str)
    df[abundance_col] = pd.to_numeric(df[abundance_col], errors="coerce")
    df = df.dropna(subset=["accession_id", group_col])

    if drop_unknown:
        bad = {"Unknown", "unclassified", "nan", "None"}
        df = df[~df[taxon_col].isin(bad)]

    # sample labels (one row per sample)
    labels = df.drop_duplicates("accession_id")[["accession_id", group_col]].copy()
    labels = labels[labels[group_col].notna()]

    if labels.empty:
        return pd.DataFrame(columns=[
            "disease", "taxon", "mean_Healthy", "mean_disease", "log2fc",
            "p_value", "q_value", "n_Healthy", "n_disease",
            "prev_Healthy", "prev_disease"
        ])

    if healthy_label not in set(labels[group_col].astype(str)):
        raise ValueError(f"No '{healthy_label}' found in {group_col}")

    # abundance for the ONE taxon per sample (mean if duplicated rows)
    tax_rows = df[df[taxon_col] == str(taxon)][["accession_id", abundance_col]].copy()
    tax_per_sample = tax_rows.groupby("accession_id", as_index=False)[abundance_col].mean()

    # merge onto all samples, fill missing with 0
    m = labels.merge(tax_per_sample, on="accession_id", how="left")
    m[abundance_col] = m[abundance_col].fillna(0.0)

    # split Healthy vector once
    h = m[m[group_col] == str(healthy_label)][abundance_col].to_numpy(dtype=float)
    n_h = int(h.size)
    if n_h < int(min_n_per_group):
        return pd.DataFrame(columns=[
            "disease", "taxon", "mean_Healthy", "mean_disease", "log2fc",
            "p_value", "q_value", "n_Healthy", "n_disease",
            "prev_Healthy", "prev_disease"
        ])

    mean_h = float(np.mean(h))
    prev_h = float(np.mean(h > 0))

    eps = 1e-6
    rows = []
    pvals = []

    diseases = sorted([g for g in m[group_col].unique().tolist() if g != str(healthy_label)])

    for dis in diseases:
        dvec = m[m[group_col] == str(dis)][abundance_col].to_numpy(dtype=float)
        n_d = int(dvec.size)
        if n_d < int(min_n_per_group):
            continue

        mean_d = float(np.mean(dvec))
        prev_d = float(np.mean(dvec > 0))

        # prevalence filter (either side)
        if (prev_h < float(min_prevalence)) and (prev_d < float(min_prevalence)):
            continue

        try:
            _stat, p = mannwhitneyu(h, dvec, alternative="two-sided")
            p = float(p)
        except Exception:
            p = np.nan

        log2fc = float(np.log2((mean_d + eps) / (mean_h + eps)))

        rows.append((
            str(dis), str(taxon), mean_h, mean_d, log2fc,
            p, n_h, n_d, prev_h, prev_d
        ))
        pvals.append(p)

    if not rows:
        return pd.DataFrame(columns=[
            "disease", "taxon", "mean_Healthy", "mean_disease", "log2fc",
            "p_value", "q_value", "n_Healthy", "n_disease",
            "prev_Healthy", "prev_disease"
        ])

    out = pd.DataFrame(rows, columns=[
        "disease", "taxon", "mean_Healthy", "mean_disease", "log2fc",
        "p_value", "n_Healthy", "n_disease", "prev_Healthy", "prev_disease"
    ])

    q = benjamini_hochberg(np.where(pd.isna(out["p_value"]).to_numpy(), 1.0, out["p_value"].to_numpy(dtype=float)))
    out["q_value"] = q.astype(float)

    return out.sort_values(["q_value", "p_value"], ascending=[True, True], na_position="last").reset_index(drop=True)

def taxon_enriched_depleted_summary(
    stats_long: pd.DataFrame,
    taxon: str,
    q_cut: float = 0.05,
    fc_cut: float = 0.0,
) -> Tuple[pd.DataFrame, pd.DataFrame]:
    if stats_long is None or stats_long.empty:
        empty = pd.DataFrame(columns=["disease", "log2fc", "q_value", "mean_Healthy", "mean_disease"])
        return empty, empty

    d = stats_long[stats_long["taxon"].astype(str) == str(taxon)].copy()
    if d.empty:
        empty = pd.DataFrame(columns=["disease", "log2fc", "q_value", "mean_Healthy", "mean_disease"])
        return empty, empty

    d["q_value"] = pd.to_numeric(d["q_value"], errors="coerce")
    d["log2fc"] = pd.to_numeric(d["log2fc"], errors="coerce")

    sig = d[d["q_value"] <= float(q_cut)].copy()
    enriched = sig[sig["log2fc"] > float(fc_cut)].sort_values(["log2fc", "q_value"], ascending=[False, True])
    depleted = sig[sig["log2fc"] < -float(fc_cut)].sort_values(["log2fc", "q_value"], ascending=[True, True])

    cols = [
        "disease",
        "log2fc",
        "q_value",
        "mean_Healthy",
        "mean_disease",
        "prev_Healthy",
        "prev_disease",
        "n_Healthy",
        "n_disease",
        "p_value",
    ]
    enriched = enriched[cols].reset_index(drop=True)
    depleted = depleted[cols].reset_index(drop=True)
    return enriched, depleted


