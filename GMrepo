def page_pairwise_group_comparison(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> None:
    st.header("Pairwise Group Comparison")

    filters = collect_sample_filters(samples)
    joined = get_filtered_abundance(samples, abund, taxa, filters)
    if joined.empty:
        st.warning("No rows after filtering. Try loosening filters.")
        return

    group_col = get_group_col(joined)
    if group_col is None:
        st.error("Could not find 'phenotype' or 'disease' after filtering.")
        st.stop()

    joined_ranked, rank_level, msg = filter_rank_level(joined)
    if msg:
        st.caption(msg)

    groups = sorted(joined_ranked[group_col].dropna().astype(str).unique().tolist())
    if len(groups) < 2:
        st.error("Not enough groups to compare.")
        st.stop()

    default_a = "Healthy" if "Healthy" in groups else groups[0]
    c1, c2 = st.columns(2)
    with c1:
        group_a = st.selectbox("Group A", groups, index=groups.index(default_a) if default_a in groups else 0)
    with c2:
        b_candidates = [g for g in groups if g != group_a]
        group_b = st.selectbox("Group B", b_candidates, index=0)

    st.caption("Test: Mann–Whitney U per taxon, BH-FDR for q-values.")

    min_prev = st.slider("Minimum prevalence in either group", 0.0, 1.0, 0.1, 0.05)
    top_k = st.slider("Number of taxa to display", 5, 50, 20, 5)
    q_cut = st.slider("Significance threshold (q)", 0.0, 0.25, 0.05, 0.01)

    if st.button("Run pairwise comparison"):
        res = compute_group_comparison_vectorized(
            df=joined_ranked,
            group_col=group_col,
            group_a=group_a,
            group_b=group_b,
            abundance_col="relative_abundance",
            taxon_col="scientific_name",
            min_prevalence=float(min_prev),
        )

        if res.empty:
            st.warning("No taxa passed filters or insufficient data.")
            st.stop()

        res2 = res.copy()
        res2["abs_log2fc"] = res2["log2fc"].abs()
        sig = res2[pd.to_numeric(res2["qvalue"], errors="coerce") <= q_cut]

        show = (
            sig.sort_values("abs_log2fc", ascending=False).head(top_k)
            if len(sig) > 0
            else res2.sort_values("abs_log2fc", ascending=False).head(top_k)
        ).sort_values("log2fc")

        st.subheader("Top changing taxa")
        fig = px.bar(show, x="scientific_name", y="log2fc", title=f"Log2 fold change: {group_b} vs {group_a}")
        fig.update_layout(xaxis_title="Taxon", yaxis_title="log2 fold change")
        st.plotly_chart(fig, width="stretch")

        st.subheader("Volcano plot")
        volc = res2.copy()
        qv = pd.to_numeric(volc["qvalue"], errors="coerce").fillna(1.0).to_numpy()
        volc["neglog10_q"] = -np.log10(np.clip(qv, 1e-300, 1.0))
        fig2 = px.scatter(volc, x="log2fc", y="neglog10_q", hover_data=["scientific_name", "pvalue", "qvalue"])
        fig2.update_layout(xaxis_title="log2 fold change", yaxis_title="-log10(q)")
        st.plotly_chart(fig2, width="stretch")

        st.subheader("Results table")
        st.dataframe(res, width="stretch")

        csv_bytes = res.to_csv(index=False).encode("utf-8")
        st.download_button(
            "Download results as CSV",
            data=csv_bytes,
            file_name=f"group_comparison_{group_a}_vs_{group_b}.csv".replace(" ", "_"),
            mime="text/csv",
        )



def page_disease_taxon_atlas(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> None:
    st.header("Disease & Taxon Atlas")

    filters = collect_sample_filters(samples)
    joined = get_filtered_abundance(samples, abund, taxa, filters)
    if joined.empty:
        st.warning("No rows after filtering. Try loosening filters.")
        return

    group_col = get_group_col(joined)
    if group_col is None:
        st.error("Could not find 'phenotype' or 'disease' after filtering.")
        st.stop()

    joined_ranked, rank_level, msg = filter_rank_level(joined)
    if msg:
        st.caption(msg)

    groups = sorted(joined_ranked[group_col].dropna().astype(str).unique().tolist())
    healthy_label = "Healthy"
    has_healthy = healthy_label in groups

    st.subheader("A) Disease composition (top taxa)")
    diseases = sorted([g for g in groups if g != healthy_label])
    if not diseases:
        st.info("No disease groups found (only Healthy detected).")
    else:
        c1, c2, c3 = st.columns([2, 1, 1])
        with c1:
            dis = st.selectbox("Disease", diseases)
        with c2:
            top_n = st.slider("Top N taxa", 10, 100, 30, 5)
        with c3:
            agg = st.selectbox("Aggregation", ["mean", "median"], index=0)

        comp = disease_composition_table(
            joined=joined_ranked,
            group_col=group_col,
            disease=dis,
            rank_level=rank_level,
            top_n=int(top_n),
            agg=str(agg),
            drop_unknown=True,
        )

        st.dataframe(comp, width="stretch")
        if not comp.empty:
            figc = px.bar(comp.sort_values("abundance"), x="taxon", y="abundance", title=f"{dis}: Top taxa abundance ({agg})")
            figc.update_layout(xaxis_title="Taxon", yaxis_title="Abundance", xaxis={"categoryorder": "total ascending"})
            st.plotly_chart(figc, width="stretch")

        st.divider()
    st.subheader("B) Single disease composition (detailed view)")

    c1, c2, c3, c4 = st.columns([2, 1, 1, 1])
    with c1:
        dis2 = st.selectbox("Disease (or group) for detailed view", diseases if diseases else groups, key="dis_detail")
    with c2:
        top_n2 = st.slider("Top N", 10, 500, 100, 10, key="topn_detail")
    with c3:
        agg2 = st.selectbox("Aggregation", ["mean", "median"], index=0, key="agg_detail")
    with c4:
        drop_unknown2 = st.checkbox("Drop Unknown/unclassified", value=True, key="dropunk_detail")

    st.caption("This shows abundance and prevalence within the selected disease only. No cross-disease testing.")

    comp2 = disease_composition_table(
        joined=joined_ranked,
        group_col=group_col,
        disease=dis2,
        rank_level=rank_level,
        top_n=int(top_n2),
        agg=str(agg2),
        drop_unknown=bool(drop_unknown2),
    )

    if comp2.empty:
        st.warning("No data for this selection. Try different filters or rank level.")
        return

    # Optional extra filtering within the disease
    with st.expander("Extra filters (within this disease)", expanded=False):
        min_prev = st.slider("Min prevalence", 0.0, 1.0, 0.0, 0.05, key="minprev_detail")
        min_abund = st.number_input("Min abundance", min_value=0.0, value=0.0, step=0.0001, key="minabund_detail")
        query = st.text_input("Search taxon name contains", value="", key="query_detail").strip().lower()

    comp_view = comp2.copy()
    comp_view["prevalence"] = pd.to_numeric(comp_view["prevalence"], errors="coerce")
    comp_view["abundance"] = pd.to_numeric(comp_view["abundance"], errors="coerce")

    if min_prev > 0:
        comp_view = comp_view[comp_view["prevalence"] >= float(min_prev)]
    if min_abund > 0:
        comp_view = comp_view[comp_view["abundance"] >= float(min_abund)]
    if query:
        comp_view = comp_view[comp_view["taxon"].astype(str).str.lower().str.contains(query, na=False)]

    st.caption(f"Rows shown: {len(comp_view):,} (from top {int(top_n2)} before filtering)")
    st.dataframe(comp_view, width="stretch")

    if not comp_view.empty:
        figb = px.bar(
            comp_view.sort_values("abundance").tail(50),  # keep plot readable
            x="taxon",
            y="abundance",
            hover_data=["prevalence"],
            title=f"{dis2}: abundance ({agg2}), showing up to 50 taxa",
        )
        figb.update_layout(xaxis_title="Taxon", yaxis_title="Abundance", xaxis={"categoryorder": "total ascending"})
        st.plotly_chart(figb, width="stretch")

        figp = px.bar(
            comp_view.sort_values("prevalence").tail(50),
            x="taxon",
            y="prevalence",
            title=f"{dis2}: prevalence, showing up to 50 taxa",
        )
        figp.update_layout(xaxis_title="Taxon", yaxis_title="Prevalence", xaxis={"categoryorder": "total ascending"})
        st.plotly_chart(figp, width="stretch")

    csv_bytes = comp_view.to_csv(index=False).encode("utf-8")
    st.download_button(
        "Download detailed composition CSV",
        data=csv_bytes,
        file_name=f"{dis2}_composition_detailed.csv".replace(" ", "_"),
        mime="text/csv",
        key="dl_detail_comp",
    )


