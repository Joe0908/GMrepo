        group_options_all = sorted(samples["phenotype"].dropna().astype(str).unique().tolist())
    elif "disease" in samples.columns and samples["disease"].notna().any():
        group_options_all = sorted(samples["disease"].dropna().astype(str).unique().tolist())
    else:
        group_options_all = []

    healthy_label = "Healthy"
    diseases_only = [g for g in group_options_all if g != healthy_label]
    selectable_groups = diseases_only if diseases_only else group_options_all

    if not selectable_groups:
        st.warning("No disease/phenotype groups found in sample_metadata.")
        return

    # ---- All UI controls render immediately (single form) ----
    with st.form("atlas_form_all_controls"):
        st.subheader("Selections")

        # Disease/group at the TOP + rank level beside it (trimmed UI)
        c1, c2, _ = st.columns([2, 2, 1])
        with c1:
            selectable_groups = sorted([str(x) for x in selectable_groups if pd.notna(x)])
            dis = st.selectbox(
                "Disease / group",
                selectable_groups,
                index=None,  # no default selection, encourages typing
                placeholder="Type e.g. 'Alc' to find Alcoholism",
                key="atlas_dis",
            )
        with c2:
            if rank_levels_all:
                rank_level = st.selectbox("Taxon rank level", rank_levels_all, index=0, key="rank_level_atlas")
            else:
                rank_level = None
                st.caption("No taxon_rank_level found. Using all rows.")

        # Advanced settings (collapsed by default)
        with st.expander("Advanced settings", expanded=False):
            c1, c2, c3 = st.columns(3)
            with c1:
                top_n2 = st.slider("Top N", 10, 500, 100, 10, key="atlas_topn_detail")
            with c2:
                agg2 = st.selectbox("Aggregation", ["mean", "median"], index=0, key="atlas_agg_detail")
            with c3:
                drop_unknown = st.checkbox("Drop Unknown/unclassified", value=True, key="atlas_dropunk")

            with st.expander("Extra filters (within this disease/group)", expanded=False):
                min_prev = st.slider("Minimum prevalence", 0.0, 1.0, 0.0, 0.05, key="atlas_minprev_detail")
                min_abund = st.number_input(
                    "Minimum abundance",
                    min_value=0.0,
                    value=0.0,
                    step=0.0001,
                    key="atlas_minabund_detail",
                )
                query = st.text_input("Search taxon name contains", value="", key="atlas_query_detail").strip().lower()

        # Optional cohort filters (collapsed)
        filters = collect_sample_filters(samples, expanded=False, key_prefix="atlas_flt")

        st.divider()
        show_results = st.form_submit_button("Show results", type="primary")

    if not show_results:
        st.info('Adjust selections and click "Show results". Expensive computation runs only after submit.')
        return

    # ---- expensive work starts here (after submit) ----
    joined = get_filtered_abundance(samples, abund, taxa, filters)
    if joined.empty:
        st.warning("No rows after filtering. Try loosening filters.")
        return

    group_col = get_group_col(joined)
    if group_col is None:
        st.error("Could not find 'phenotype' or 'disease' after filtering.")
        st.stop()

    # Apply rank filter after join
    if rank_level is not None and "taxon_rank_level" in joined.columns:
        joined_ranked = joined[joined["taxon_rank_level"].astype(str) == str(rank_level)].copy()
    else:
        joined_ranked = joined

    # Validate selected group exists after filtering
    groups_after = sorted(joined_ranked[group_col].dropna().astype(str).unique().tolist())
    if str(dis) not in set(groups_after):
        st.warning("Selected disease/group has no samples after filtering. Try loosening filters.")
        return

    st.subheader("Disease composition")
    st.caption("Filtered detailed table and charts for the selected disease/group.")

    comp2 = disease_composition_table(
        joined=joined_ranked,
        group_col=group_col,
        disease=dis,
        rank_level=rank_level,
        top_n=int(top_n2),
        agg=str(agg2),
        drop_unknown=bool(drop_unknown),
    )
    if comp2.empty:
        st.warning("No data available for this selection. Try different filters or rank level.")
        return

    comp_view = comp2.copy()
    comp_view["prevalence"] = pd.to_numeric(comp_view["prevalence"], errors="coerce")
    comp_view["abundance"] = pd.to_numeric(comp_view["abundance"], errors="coerce")

    if float(min_prev) > 0:
        comp_view = comp_view[comp_view["prevalence"] >= float(min_prev)]
    if float(min_abund) > 0:
        comp_view = comp_view[comp_view["abundance"] >= float(min_abund)]
    if query:
        comp_view = comp_view[comp_view["taxon"].astype(str).str.lower().str.contains(query, na=False)]

    st.caption(f"Rows shown: {len(comp_view):,} (from top {int(top_n2)} before extra filtering)")

    csv_bytes = comp_view.to_csv(index=False).encode("utf-8")
    st.download_button(
        "Download composition CSV",
        data=csv_bytes,
        file_name=f"{dis}_composition.csv".replace(" ", "_"),
        mime="text/csv",
        key="atlas_dl_detail_comp",
    )

    st.dataframe(comp_view, use_container_width=True)

    if not comp_view.empty:
        top_n_plot = int(top_n2)

        # Figure 1: Top taxa by abundance (uses mean/median from agg2)
        plot_ab = (
            comp_view.sort_values(["abundance", "prevalence"], ascending=[False, False])
            .head(top_n_plot)
            .copy()
        )

        fig_ab = px.bar(
            plot_ab.iloc[::-1],  # reverse so biggest is at top/right visually
            x="taxon",
            y="abundance",
            hover_data=["prevalence", "n_samples"],
            title=f"Top {len(plot_ab)} taxa by abundance ({agg2}) in {dis}",
        )
        fig_ab.update_layout(
            xaxis_title="Taxon",
            yaxis_title=f"Abundance ({agg2})",
            xaxis={"categoryorder": "total ascending"},
        )
        st.plotly_chart(fig_ab, use_container_width=True)

        # Figure 2: Top taxa by prevalence (prevalence is not affected by mean/median)
        plot_prev = (
            comp_view.sort_values(["prevalence", "abundance"], ascending=[False, False])
            .head(top_n_plot)
            .copy()
        )

        fig_prev = px.bar(
            plot_prev.iloc[::-1],
            x="taxon",
            y="prevalence",
            hover_data=["abundance", "n_samples"],
            title=f"Top {len(plot_prev)} taxa by prevalence ({agg2}) in {dis}",
        )
        fig_prev.update_layout(
            xaxis_title="Taxon",
            yaxis_title=f"Prevalence({agg2})",
            xaxis={"categoryorder": "total ascending"},
        )
        st.plotly_chart(fig_prev, use_container_width=True)

    
