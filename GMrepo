@st.cache_data(show_spinner=False)
def load_data(paths: DataPaths) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    # Read with stable dtypes up-front to avoid expensive post-hoc conversions.
    sample_types = {
        "country": "category",
        "phenotype": "category",
        "disease": "category",
        "experiment_type": "category",
        "recent_antibiotics_use": "category",
    }
    samples = _standardize_columns(_read_table(paths.sample_metadata, dtype=sample_types))

    abund_types = {
        "accession_id": "string",
        "ncbi_taxon_id": "string",
        "taxon_rank_level": "category",
        "relative_abundance": "float32",
    }
    abund = _standardize_columns(_read_table(paths.abundance, dtype=abund_types))

    taxa_types = {
        "ncbi_taxon_id": "string",
        "scientific_name": "string",
        "taxon_rank_level": "category",
    }
    taxa = _standardize_columns(_read_table(paths.taxonomy, dtype=taxa_types))

    # If relative_abundance could not be parsed as float32 for some rows, coerce once here.
    if "relative_abundance" in abund.columns and not pd.api.types.is_numeric_dtype(abund["relative_abundance"]):
        abund["relative_abundance"] = pd.to_numeric(abund["relative_abundance"], errors="coerce")

    return samples, abund, taxa


