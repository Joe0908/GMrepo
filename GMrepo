def collect_sample_filters(samples: pd.DataFrame) -> dict:
    """Build filter UI off sample metadata only, then filter abundance before any merges."""
    filters: dict = {}
    with st.expander("Optional filters"):
        for col, label in [
            ("experiment_type", "Experiment type"),
            ("country", "Country"),
            ("recent_antibiotics_use", "Recent antibiotics use"),
        ]:
            if col in samples.columns and samples[col].notna().any():
                options = ["All"] + sorted(samples[col].dropna().astype(str).unique().tolist())
                choice = st.selectbox(label, options, key=f"flt_{col}")
                filters[col] = choice
            else:
                st.caption(f"No {col} column available (or all empty).")
    return filters


@st.cache_data(show_spinner=False)
def get_filtered_abundance(
    samples: pd.DataFrame,
    abund: pd.DataFrame,
    taxa: pd.DataFrame,
    filters: dict,
) -> pd.DataFrame:
    s_filtered = samples

    for col, value in (filters or {}).items():
        if value != "All" and col in s_filtered.columns:
            s_filtered = s_filtered[s_filtered[col].astype(str) == str(value)]

    if "run_id" not in s_filtered.columns:
        raise ValueError("sample_metadata must contain 'run_id'")

    valid_ids = pd.Index(s_filtered["run_id"].astype(str).unique())
    if valid_ids.empty:
        return pd.DataFrame()

    if "accession_id" not in abund.columns:
        raise ValueError("abundance must contain 'accession_id'")

    a_filtered = abund[abund["accession_id"].astype(str).isin(valid_ids)].copy()
    if a_filtered.empty:
        return pd.DataFrame()

    # Join taxa names (keep only the needed columns)
    if "scientific_name" not in taxa.columns:
        t = taxa.copy()
        for alt in ["name", "taxon_name"]:
            if alt in t.columns:
                t = t.rename(columns={alt: "scientific_name"})
                break
        taxa2 = t
    else:
        taxa2 = taxa

    t_subset_cols = ["ncbi_taxon_id", "scientific_name"]
    if "taxon_rank_level" in taxa2.columns:
        t_subset_cols.append("taxon_rank_level")

    t_subset = taxa2[t_subset_cols].drop_duplicates()

    merged = a_filtered.merge(t_subset, on="ncbi_taxon_id", how="left")

    # Attach group label only (phenotype preferred, else disease)
    if "phenotype" in s_filtered.columns:
        group_col = "phenotype"
    elif "disease" in s_filtered.columns:
        group_col = "disease"
    else:
        group_col = None

    if group_col is None:
        raise ValueError("sample_metadata must contain 'phenotype' or 'disease'")

    group_info = s_filtered[["run_id", group_col]].copy()
    final = merged.merge(group_info, left_on="accession_id", right_on="run_id", how="inner")

    return final


