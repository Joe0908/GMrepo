@st.cache_data(show_spinner=False)
def disease_composition_table(
    joined: pd.DataFrame,
    group_col: str,
    disease: str,
    rank_level: Optional[str] = None,
    taxon_col: str = "scientific_name",
    abundance_col: str = "relative_abundance",
    top_n: int = 30,
    agg: str = "mean",
    drop_unknown: bool = True,
) -> pd.DataFrame:
    df = joined.copy()

    for c in [group_col, taxon_col, abundance_col]:
        if c not in df.columns:
            raise ValueError(f"joined missing column: {c}")

    if rank_level is not None and "taxon_rank_level" in df.columns:
        df = df[df["taxon_rank_level"].astype(str) == str(rank_level)]

    df[group_col] = df[group_col].astype(str)
    df = df[df[group_col] == str(disease)].copy()

    df[abundance_col] = pd.to_numeric(df[abundance_col], errors="coerce")
    df = df.dropna(subset=[taxon_col, abundance_col])

    if drop_unknown:
        df = df[~df[taxon_col].astype(str).isin(["Unknown", "unclassified"])]

    if df.empty:
        return pd.DataFrame(columns=["taxon", "abundance", "prevalence", "n_samples"])

    sample_col = "accession_id" if "accession_id" in df.columns else ("run_id" if "run_id" in df.columns else None)
    if sample_col is None:
        raise ValueError("no sample id column found (accession_id/run_id)")

    pivot = df.pivot_table(index=sample_col, columns=taxon_col, values=abundance_col, fill_value=0.0)

    abund = pivot.median(axis=0) if agg == "median" else pivot.mean(axis=0)
    prev = (pivot > 0).mean(axis=0)
    n_samples = int(pivot.shape[0])

    out = pd.DataFrame(
        {
            "taxon": abund.index.astype(str),
            "abundance": abund.values.astype(float),
            "prevalence": prev.values.astype(float),
            "n_samples": n_samples,
        }
    )
    out = out.sort_values(["abundance", "prevalence"], ascending=[False, False]).head(int(top_n)).reset_index(drop=True)
    return out


@st.cache_data(show_spinner=False)
def taxon_enrichment_matrix_vs_healthy(
    joined: pd.DataFrame,
    group_col: str,
    rank_level: Optional[str] = None,
    healthy_label: str = "Healthy",
    taxon_col: str = "scientific_name",
    abundance_col: str = "relative_abundance",
    min_prevalence: float = 0.1,
    min_n_per_group: int = 8,
    drop_unknown: bool = True,
) -> pd.DataFrame:
    df = joined.copy()

    for c in [group_col, taxon_col, abundance_col]:
        if c not in df.columns:
            raise ValueError(f"joined missing column: {c}")

    if rank_level is not None and "taxon_rank_level" in df.columns:
        df = df[df["taxon_rank_level"].astype(str) == str(rank_level)]

    df[group_col] = df[group_col].astype(str)
    groups = sorted(df[group_col].dropna().unique().tolist())
    if healthy_label not in groups:
        raise ValueError(f"no '{healthy_label}' found in {group_col}")

    diseases = [g for g in groups if g != healthy_label]
    if not diseases:
        return pd.DataFrame()

    df[abundance_col] = pd.to_numeric(df[abundance_col], errors="coerce")
    df = df.dropna(subset=[taxon_col, abundance_col])

    if drop_unknown:
        df = df[~df[taxon_col].astype(str).isin(["Unknown", "unclassified"])]

    sample_col = "accession_id" if "accession_id" in df.columns else ("run_id" if "run_id" in df.columns else None)
    if sample_col is None:
        raise ValueError("no sample id column found (accession_id/run_id)")

    rows_all = []

    for dis in diseases:
        sub = df[df[group_col].isin([healthy_label, dis])].copy()
        if sub.empty:
            continue

        pivot = sub.pivot_table(index=[sample_col, group_col], columns=taxon_col, values=abundance_col, fill_value=0.0)

        idx = pivot.index
        grp_vals = idx.get_level_values(1).astype(str)
        X = pivot.reset_index(level=1, drop=True)

        mask_h = grp_vals == healthy_label
        mask_d = grp_vals == dis

        n_h = int(mask_h.sum())
        n_d = int(mask_d.sum())
        if n_h < int(min_n_per_group) or n_d < int(min_n_per_group):
            continue

        X_h = X.loc[mask_h]
        X_d = X.loc[mask_d]

        mean_h = X_h.mean(axis=0)
        mean_d = X_d.mean(axis=0)
        prev_h = (X_h > 0).mean(axis=0)
        prev_d = (X_d > 0).mean(axis=0)

        keep = (prev_h >= float(min_prevalence)) | (prev_d >= float(min_prevalence))
        taxa_keep = X.columns[keep.values]

        eps = 1e-6
        pvals = []
        tmp = []

        for tax in taxa_keep:
            a = X_h[tax].to_numpy()
            b = X_d[tax].to_numpy()

            p = np.nan
            if a.size > 1 and b.size > 1:
                try:
                    p = float(mannwhitneyu(a, b, alternative="two-sided").pvalue)
                except Exception:
                    p = np.nan

            mh = float(mean_h[tax])
            md = float(mean_d[tax])
            log2fc = float(np.log2((md + eps) / (mh + eps)))

            tmp.append(
                (
                    dis,
                    str(tax),
                    mh,
                    md,
                    log2fc,
                    p,
                    n_h,
                    n_d,
                    float(prev_h[tax]),
                    float(prev_d[tax]),
                )
            )
            pvals.append(1.0 if np.isnan(p) else p)

        if not tmp:
            continue

        qvals = benjamini_hochberg(np.asarray(pvals, dtype=float))
        for i, row in enumerate(tmp):
            rows_all.append(row + (float(qvals[i]),))

    out = pd.DataFrame(
        rows_all,
        columns=[
            "disease",
            "taxon",
            "mean_Healthy",
            "mean_disease",
            "log2fc",
            "p_value",
            "n_Healthy",
            "n_disease",
            "prev_Healthy",
            "prev_disease",
            "q_value",
        ],
    )
    return out


def taxon_enriched_depleted_summary(
    stats_long: pd.DataFrame,
    taxon: str,
    q_cut: float = 0.05,
    fc_cut: float = 0.0,
) -> Tuple[pd.DataFrame, pd.DataFrame]:
    if stats_long is None or stats_long.empty:
        empty = pd.DataFrame(columns=["disease", "log2fc", "q_value", "mean_Healthy", "mean_disease"])
        return empty, empty

    d = stats_long[stats_long["taxon"].astype(str) == str(taxon)].copy()
    if d.empty:
        empty = pd.DataFrame(columns=["disease", "log2fc", "q_value", "mean_Healthy", "mean_disease"])
        return empty, empty

    d["q_value"] = pd.to_numeric(d["q_value"], errors="coerce")
    d["log2fc"] = pd.to_numeric(d["log2fc"], errors="coerce")

    sig = d[d["q_value"] <= float(q_cut)].copy()

    enriched = sig[sig["log2fc"] > float(fc_cut)].sort_values(["log2fc", "q_value"], ascending=[False, True])
    depleted = sig[sig["log2fc"] < -float(fc_cut)].sort_values(["log2fc", "q_value"], ascending=[True, True])

    cols = [
        "disease",
        "log2fc",
        "q_value",
        "mean_Healthy",
        "mean_disease",
        "prev_Healthy",
        "prev_disease",
        "n_Healthy",
        "n_disease",
    ]
    return enriched[cols].reset_index(drop=True), depleted[cols].reset_index(drop=True)


