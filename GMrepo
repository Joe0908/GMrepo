def page_home(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> None:
    st.title(APP_TITLE)

    st.markdown(
        """
Welcome to GMRepo v2 Minimal Explorer.

How to use:
1) Choose a page from the sidebar.
2) On each page, first choose optional filters.
3) Select a disease/group or taxon settings as instructed.
4) Charts and tables appear only after you make selections (and click the run button when provided).

Pages:
- Disease & Taxon Atlas: explore microbiome composition within a selected disease/group.
- Taxon Across Diseases: pick a taxon and see which diseases it is enriched/depleted in (vs Healthy).
- Pairwise Group Comparison: compare two groups and identify taxa that differ.
        """
    )

    st.divider()

    total_samples = safe_unique_count(samples.get("run_id"))
    total_projects = safe_unique_count(samples.get("project_id"))
    total_groups = safe_unique_count(samples.get("phenotype")) or safe_unique_count(samples.get("disease"))
    unique_taxa = safe_unique_count(abund.get("ncbi_taxon_id"))

    c1, c2, c3, c4 = st.columns(4)
    c1.metric("Total samples (runs)", f"{total_samples:,}")
    c2.metric("Studies (projects)", f"{total_projects:,}")
    c3.metric("Groups", f"{total_groups:,}")
    c4.metric("Unique taxa IDs", f"{unique_taxa:,}")

    st.divider()

    show_overview = st.checkbox("Show quick overview charts", value=False, key="home_show_overview")
    if not show_overview:
        st.info("Enable the checkbox above if you want quick dataset overview charts.")
        return

    if "experiment_type" in samples.columns and samples["experiment_type"].notna().any():
        vc = samples["experiment_type"].astype("string").fillna("Unknown").value_counts()
        fig = px.pie(names=vc.index.tolist(), values=vc.values.tolist(), title="Sequencing types")
        st.plotly_chart(fig, use_container_width=True)

    disease_col = "phenotype" if "phenotype" in samples.columns else ("disease" if "disease" in samples.columns else None)
    if disease_col and samples[disease_col].notna().any():
        vc = samples[disease_col].astype("string").fillna("Unknown").value_counts().head(10)
        top = pd.DataFrame({disease_col: vc.index.tolist(), "n_samples": vc.values.tolist()})
        fig = px.bar(top, x=disease_col, y="n_samples", title=f"Top 10 {disease_col} by sample count")
        fig.update_layout(xaxis_title=disease_col, yaxis_title="Number of samples")
        st.plotly_chart(fig, use_container_width=True)


def page_disease_taxon_atlas(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> None:
    st.header("Disease & Taxon Atlas")

    st.markdown(
        """
Explore microbiome composition within a selected disease/group.

Workflow:
1) Apply optional filters.
2) Choose a taxonomic rank level.
3) Select a disease/group and click "Show results".
        """
    )

    st.divider()

    filters = collect_sample_filters(samples)
    joined = get_filtered_abundance(samples, abund, taxa, filters)
    if joined.empty:
        st.warning("No rows after filtering. Try loosening filters.")
        return

    group_col = get_group_col(joined)
    if group_col is None:
        st.error("Could not find 'phenotype' or 'disease' after filtering.")
        st.stop()

    joined_ranked, rank_level, msg = filter_rank_level(joined, key="rank_level_atlas")
    if msg:
        st.caption(msg)

    groups = sorted(joined_ranked[group_col].dropna().astype(str).unique().tolist())
    if not groups:
        st.warning("No groups found after filtering.")
        return

    healthy_label = "Healthy"
    diseases = sorted([g for g in groups if g != healthy_label])
    selectable = diseases if diseases else groups

    st.subheader("Selections")
    c1, c2, c3, c4 = st.columns([2, 1, 1, 1])
    with c1:
        dis = st.selectbox("Disease / group", selectable, key="atlas_dis")
    with c2:
        top_n = st.slider("Top N taxa", 10, 200, 30, 5, key="atlas_topn")
    with c3:
        agg = st.selectbox("Aggregation", ["mean", "median"], index=0, key="atlas_agg")
    with c4:
        drop_unknown = st.checkbox("Drop Unknown/unclassified", value=True, key="atlas_dropunk")

    show_results = st.button("Show results", type="primary", key="atlas_show")
    if not show_results:
        st.info('Select a disease/group and click "Show results" to display charts and tables.')
        return

    st.subheader("A) Disease composition (top taxa)")
    comp = disease_composition_table(
        joined=joined_ranked,
        group_col=group_col,
        disease=dis,
        rank_level=rank_level,
        top_n=int(top_n),
        agg=str(agg),
        drop_unknown=bool(drop_unknown),
    )
    if comp.empty:
        st.warning("No data for this selection. Try different filters or rank level.")
        return

    st.dataframe(comp, use_container_width=True)
    figc = px.bar(
        comp.sort_values("abundance"),
        x="taxon",
        y="abundance",
        title=f"{dis}: Top taxa abundance ({agg})",
    )
    figc.update_layout(xaxis_title="Taxon", yaxis_title="Abundance", xaxis={"categoryorder": "total ascending"})
    st.plotly_chart(figc, use_container_width=True)

    st.divider()

    st.subheader("B) Single disease composition (detailed view)")
    st.caption("Abundance and prevalence within the selected disease/group only.")

    c1, c2 = st.columns([1, 1])
    with c1:
        top_n2 = st.slider("Top N (detailed)", 10, 500, 100, 10, key="atlas_topn_detail")
    with c2:
        agg2 = st.selectbox("Aggregation (detailed)", ["mean", "median"], index=0, key="atlas_agg_detail")

    comp2 = disease_composition_table(
        joined=joined_ranked,
        group_col=group_col,
        disease=dis,
        rank_level=rank_level,
        top_n=int(top_n2),
        agg=str(agg2),
        drop_unknown=bool(drop_unknown),
    )
    if comp2.empty:
        st.warning("No data available for the detailed view. Try different filters or rank level.")
        return

    with st.expander("Extra filters (within this disease/group)", expanded=False):
        min_prev = st.slider("Minimum prevalence", 0.0, 1.0, 0.0, 0.05, key="atlas_minprev_detail")
        min_abund = st.number_input("Minimum abundance", min_value=0.0, value=0.0, step=0.0001, key="atlas_minabund_detail")
        query = st.text_input("Search taxon name contains", value="", key="atlas_query_detail").strip().lower()

    comp_view = comp2.copy()
    comp_view["prevalence"] = pd.to_numeric(comp_view["prevalence"], errors="coerce")
    comp_view["abundance"] = pd.to_numeric(comp_view["abundance"], errors="coerce")

    if min_prev > 0:
        comp_view = comp_view[comp_view["prevalence"] >= float(min_prev)]
    if min_abund > 0:
        comp_view = comp_view[comp_view["abundance"] >= float(min_abund)]
    if query:
        comp_view = comp_view[comp_view["taxon"].astype(str).str.lower().str.contains(query, na=False)]

    st.caption(f"Rows shown: {len(comp_view):,} (from top {int(top_n2)} before extra filtering)")
    st.dataframe(comp_view, use_container_width=True)

    if not comp_view.empty:
