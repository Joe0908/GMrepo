def page_home(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> None:
    st.title(APP_TITLE)
    st.write("Minimal build with caching for faster interaction.")

    total_samples = safe_unique_count(samples.get("run_id"))
    total_projects = safe_unique_count(samples.get("project_id"))
    total_phenotypes = safe_unique_count(samples.get("phenotype")) or safe_unique_count(samples.get("disease"))
    unique_taxa = safe_unique_count(abund.get("ncbi_taxon_id"))

    c1, c2, c3, c4 = st.columns(4)
    c1.metric("Total samples (runs)", f"{total_samples:,}")
    c2.metric("Studies (projects)", f"{total_projects:,}")
    c3.metric("Phenotypes", f"{total_phenotypes:,}")
    c4.metric("Unique taxa IDs", f"{unique_taxa:,}")

    st.divider()

    if "experiment_type" in samples.columns:
        vc = samples["experiment_type"].fillna("Unknown").astype(str).value_counts()
        fig = px.pie(names=vc.index.tolist(), values=vc.values.tolist(), title="Sequencing types")
        st.plotly_chart(fig, use_container_width=True)

    disease_col = "phenotype" if "phenotype" in samples.columns else ("disease" if "disease" in samples.columns else None)
    if disease_col:
        vc = samples[disease_col].fillna("Unknown").astype(str).value_counts().head(10)
        top = pd.DataFrame({disease_col: vc.index.tolist(), "n_samples": vc.values.tolist()})
        fig = px.bar(top, x=disease_col, y="n_samples", title=f"Top 10 {disease_col} by sample count")
        fig.update_layout(xaxis_title=disease_col, yaxis_title="Number of samples")
        st.plotly_chart(fig, use_container_width=True)

    age_col = "host_age" if "host_age" in samples.columns else None
    if age_col and samples[age_col].notna().any():
        ages = pd.to_numeric(samples[age_col], errors="coerce").dropna()
        fig = px.histogram(ages, nbins=30, title="Host age distribution")
        fig.update_layout(xaxis_title="Age", yaxis_title="Count")
        st.plotly_chart(fig, use_container_width=True)


def page_pairwise_group_comparison(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> None:
    st.header("Pairwise Group Comparison")

    joined = build_joined(samples, abund, taxa)
    group_col = get_group_col(joined)
    if group_col is None:
        st.error("Could not find 'phenotype' or 'disease' after joining.")
        st.stop()

    joined = apply_optional_filters(joined)
    joined_ranked, rank_level, msg = filter_rank_level(joined)
    if msg:
        st.caption(msg)

    groups = sorted(joined_ranked[group_col].dropna().astype(str).unique().tolist())
    if len(groups) < 2:
        st.error("Not enough groups to compare.")
        st.stop()

    default_a = "Healthy" if "Healthy" in groups else groups[0]
    c1, c2 = st.columns(2)
    with c1:
        group_a = st.selectbox("Group A", groups, index=groups.index(default_a) if default_a in groups else 0)
    with c2:
        b_candidates = [g for g in groups if g != group_a]
        group_b = st.selectbox("Group B", b_candidates, index=0)

    st.caption("Test: Mann–Whitney U per taxon, BH-FDR for q-values.")

    min_prev = st.slider("Minimum prevalence in either group", 0.0, 1.0, 0.1, 0.05)
    top_k = st.slider("Number of taxa to display", 5, 50, 20, 5)
    q_cut = st.slider("Significance threshold (q)", 0.0, 0.25, 0.05, 0.01)

    if st.button("Run pairwise comparison"):
        res = compute_group_comparison(
            joined=joined_ranked,
            group_col=group_col,
            group_a=group_a,
            group_b=group_b,
            taxon_name_col="scientific_name",
            abundance_col="relative_abundance",
            min_prevalence=float(min_prev),
        )

        if res.empty:
            st.warning("No taxa passed filters or insufficient data.")
            st.stop()

        res2 = res.copy()
        res2["abs_log2fc"] = res2["log2fc"].abs()
        sig = res2[pd.to_numeric(res2["qvalue"], errors="coerce") <= q_cut]

        show = (
            sig.sort_values("abs_log2fc", ascending=False).head(top_k)
            if len(sig) > 0
            else res2.sort_values("abs_log2fc", ascending=False).head(top_k)
        ).sort_values("log2fc")

        st.subheader("Top changing taxa")
        fig = px.bar(show, x="scientific_name", y="log2fc", title=f"Log2 fold change: {group_b} vs {group_a}")
        fig.update_layout(xaxis_title="Taxon", yaxis_title="log2 fold change")
        st.plotly_chart(fig, use_container_width=True)

        st.subheader("Volcano plot")
        volc = res2.copy()
        qv = pd.to_numeric(volc["qvalue"], errors="coerce").fillna(1.0).to_numpy()
        volc["neglog10_q"] = -np.log10(np.clip(qv, 1e-300, 1.0))
        fig2 = px.scatter(volc, x="log2fc", y="neglog10_q", hover_data=["scientific_name", "pvalue", "qvalue"])
        fig2.update_layout(xaxis_title="log2 fold change", yaxis_title="-log10(q)")
        st.plotly_chart(fig2, use_container_width=True)

        st.subheader("Results table")
        st.dataframe(res, use_container_width=True)

        csv_bytes = res.to_csv(index=False).encode("utf-8")
        st.download_button(
            "Download results as CSV",
            data=csv_bytes,
            file_name=f"group_comparison_{group_a}_vs_{group_b}.csv".replace(" ", "_"),
            mime="text/csv",
        )


def page_disease_taxon_atlas(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> None:
    st.header("Disease & Taxon Atlas")

    joined = build_joined(samples, abund, taxa)
    group_col = get_group_col(joined)
    if group_col is None:
        st.error("Could not find 'phenotype' or 'disease' after joining.")
        st.stop()

    joined = apply_optional_filters(joined)
    joined_ranked, rank_level, msg = filter_rank_level(joined)
    if msg:
        st.caption(msg)

    groups = sorted(joined_ranked[group_col].dropna().astype(str).unique().tolist())
    healthy_label = "Healthy"
    has_healthy = healthy_label in groups

    st.subheader("A) Disease composition (top taxa)")
    diseases = sorted([g for g in groups if g != healthy_label])
    if not diseases:
        st.info("No disease groups found (only Healthy detected).")
    else:
        c1, c2, c3 = st.columns([2, 1, 1])
        with c1:
            dis = st.selectbox("Disease", diseases)
        with c2:
            top_n = st.slider("Top N taxa", 10, 100, 30, 5)
        with c3:
            agg = st.selectbox("Aggregation", ["mean", "median"], index=0)

        comp = disease_composition_table(
            joined=joined_ranked,
            group_col=group_col,
            disease=dis,
            rank_level=rank_level,
            top_n=int(top_n),
            agg=str(agg),
            drop_unknown=True,
        )

        st.dataframe(comp, use_container_width=True)
        if not comp.empty:
            figc = px.bar(comp.sort_values("abundance"), x="taxon", y="abundance", title=f"{dis}: Top taxa abundance ({agg})")
            figc.update_layout(xaxis_title="Taxon", yaxis_title="Abundance", xaxis={"categoryorder": "total ascending"})
            st.plotly_chart(figc, use_container_width=True)

    st.divider()
    st.subheader("B) For one taxon: enriched or depleted across diseases (vs Healthy)")

    if not has_healthy:
        st.warning("No Healthy group found. This section requires Healthy as reference.")
        return

    left, right = st.columns(2)
    with left:
        min_prev_global = st.slider("Min prevalence (either group)", 0.0, 1.0, 0.1, 0.05)
        min_n = st.slider("Min samples per group", 3, 30, 8, 1)
    with right:
        q_cut_global = st.slider("q cutoff", 0.0, 0.25, 0.05, 0.01)
        fc_cut_global = st.slider("abs(log2fc) cutoff", 0.0, 2.0, 0.0, 0.1)

    if st.button("Build or refresh disease vs Healthy matrix"):
        with st.spinner("Computing all diseases vs Healthy (cached for these settings)..."):
            stats_long = taxon_enrichment_matrix_vs_healthy(
                joined=joined_ranked,
                group_col=group_col,
                rank_level=rank_level,
                healthy_label=healthy_label,
                min_prevalence=float(min_prev_global),
                min_n_per_group=int(min_n),
                drop_unknown=True,
            )
        st.session_state["stats_long"] = stats_long
        st.success(f"Built matrix with {len(stats_long):,} rows.")

    stats_long = st.session_state.get("stats_long", None)
    if stats_long is None:
        st.info("Click the button above to build the matrix.")
        return
    if stats_long.empty:
        st.info("Matrix is empty. Lower min_n or min_prevalence and rebuild.")
        return

    taxa_list = sorted(stats_long["taxon"].dropna().astype(str).unique().tolist())
    tax = st.selectbox("Taxon", taxa_list)

    enriched, depleted = taxon_enriched_depleted_summary(
        stats_long=stats_long,
        taxon=tax,
        q_cut=float(q_cut_global),
        fc_cut=float(fc_cut_global),
    )

    c1, c2 = st.columns(2)
    with c1:
        st.write("Enriched diseases")
        st.dataframe(enriched, use_container_width=True)
    with c2:
        st.write("Depleted diseases")
        st.dataframe(depleted, use_container_width=True)

    with st.expander("Show all diseases for this taxon (including non-significant)"):
        all_d = stats_long[stats_long["taxon"].astype(str) == str(tax)].copy()
        all_d["q_value"] = pd.to_numeric(all_d["q_value"], errors="coerce")
        all_d["log2fc"] = pd.to_numeric(all_d["log2fc"], errors="coerce")
        all_d = all_d.sort_values(["q_value", "log2fc"], ascending=[True, False])
        st.dataframe(all_d, use_container_width=True)


