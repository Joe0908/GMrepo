        "Download detailed composition CSV",
        data=csv_bytes,
        file_name=f"{dis}_composition_detailed.csv".replace(" ", "_"),
        mime="text/csv",
        key="atlas_dl_detail_comp",
    )


def page_taxon_across_diseases(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> None:
    st.header("Taxon Across Diseases (Enriched/Depleted vs Healthy)")

    st.markdown(
        """
Pick a taxon (species/genus etc.) and see which diseases it is enriched or depleted in, compared to Healthy.

Workflow:
1) Apply optional filters.
2) Choose a taxonomic rank level.
3) Select a taxon and click "Show results".
        """
    )

    st.divider()

    filters = collect_sample_filters(samples)
    joined = get_filtered_abundance(samples, abund, taxa, filters)
    if joined.empty:
        st.warning("No rows after filtering. Try loosening filters.")
        return

    group_col = get_group_col(joined)
    if group_col is None:
        st.error("Could not find 'phenotype' or 'disease' after filtering.")
        st.stop()

    joined_ranked, rank_level, msg = filter_rank_level(joined, key="rank_level_taxonpage")
    if msg:
        st.caption(msg)

    groups = sorted(joined_ranked[group_col].dropna().astype(str).unique().tolist())
    healthy_label = "Healthy"
    if healthy_label not in groups:
        st.error(f"'{healthy_label}' was not found in {group_col}. This page requires a Healthy baseline.")
        st.stop()

    st.subheader("Selections")

    # Taxon selection list (can be large; allow search)
    taxa_options = (
        joined_ranked["scientific_name"]
        .astype(str)
        .replace({"nan": np.nan})
        .dropna()
        .loc[lambda s: ~s.isin(["Unknown", "unclassified"])]
        .unique()
        .tolist()
    )
    taxa_options = sorted(taxa_options)

    if not taxa_options:
        st.warning("No taxa names available after filtering.")
        return

    c1, c2, c3, c4 = st.columns([2, 1, 1, 1])
    with c1:
        query = st.text_input("Search taxon name contains", value="", key="taxonpage_query").strip().lower()

    filtered_options = taxa_options
    if query:
        filtered_options = [t for t in taxa_options if query in str(t).lower()]
        if not filtered_options:
            st.info("No taxa match this search. Try a different keyword.")
            return

    with c1:
        taxon = st.selectbox("Taxon (species/genus)", filtered_options, key="taxonpage_taxon")

    with c2:
        q_cut = st.slider("q-value cutoff", 0.0, 0.25, 0.05, 0.01, key="taxonpage_qcut")
    with c3:
        fc_cut = st.slider("log2FC threshold", 0.0, 3.0, 0.0, 0.1, key="taxonpage_fccut")
    with c4:
        min_prev = st.slider("Min prevalence", 0.0, 1.0, 0.1, 0.05, key="taxonpage_minprev")

    with st.expander("Advanced settings", expanded=False):
        min_n = st.number_input("Min samples per group (Healthy and disease)", min_value=2, value=8, step=1, key="taxonpage_minn")
        drop_unknown = st.checkbox("Drop Unknown/unclassified", value=True, key="taxonpage_dropunk")

    show = st.button("Show results", type="primary", key="taxonpage_show")
    if not show:
        st.info('Select a taxon and click "Show results" to display enriched/depleted diseases.')
        return

    # Compute long-form stats (cached)
    try:
        stats_long = taxon_enrichment_matrix_vs_healthy(
            joined=joined_ranked,
            group_col=group_col,
            rank_level=rank_level,
            healthy_label=healthy_label,
            taxon_col="scientific_name",
            abundance_col="relative_abundance",
            min_prevalence=float(min_prev),
            min_n_per_group=int(min_n),
            drop_unknown=bool(drop_unknown),
        )
    except Exception as e:
        st.error(f"Failed to compute enrichment matrix: {e}")
        return

    if stats_long is None or stats_long.empty:
        st.warning("No disease-vs-Healthy comparisons passed minimum sample/prevalence thresholds.")
        return

    enriched, depleted = taxon_enriched_depleted_summary(
        stats_long=stats_long,
        taxon=taxon,
        q_cut=float(q_cut),
        fc_cut=float(fc_cut),
    )

    st.subheader(f"Selected taxon: {taxon}")

    c1, c2 = st.columns(2)
    with c1:
        st.metric("Enriched diseases", int(len(enriched)))
    with c2:
        st.metric("Depleted diseases", int(len(depleted)))

    if enriched.empty and depleted.empty:
        st.info("No diseases passed the current thresholds. Try relaxing q-value / log2FC / min prevalence / min N.")
        # Still allow user to inspect raw per-disease rows for this taxon
        raw_tax = stats_long[stats_long["taxon"].astype(str) == str(taxon)].copy()
        if raw_tax.empty:
            return
        st.subheader("Raw per-disease results (no thresholding)")
        raw_tax = raw_tax.sort_values(["q_value", "p_value"], ascending=[True, True], na_position="last")
        st.dataframe(raw_tax, use_container_width=True)
        return

    if not enriched.empty:
        st.subheader("Enriched in diseases (vs Healthy)")
        st.dataframe(enriched, use_container_width=True)

        fig_e = px.bar(
            enriched.sort_values("log2fc", ascending=True).tail(30),
            x="disease",
            y="log2fc",
            title="Top enriched diseases (log2FC), up to 30 shown",
            hover_data=["q_value", "mean_Healthy", "mean_disease", "prev_Healthy", "prev_disease", "n_Healthy", "n_disease"],
        )
        fig_e.update_layout(xaxis_title="Disease", yaxis_title="log2FC (disease vs Healthy)")
        st.plotly_chart(fig_e, use_container_width=True)

        st.download_button(
            "Download enriched diseases CSV",
            data=enriched.to_csv(index=False).encode("utf-8"),
            file_name=f"{taxon}_enriched_vs_Healthy.csv".replace(" ", "_"),
            mime="text/csv",
            key="taxonpage_dl_enriched",
        )

    if not depleted.empty:
        st.subheader("Depleted in diseases (vs Healthy)")
        st.dataframe(depleted, use_container_width=True)

        fig_d = px.bar(
            depleted.sort_values("log2fc", ascending=True).head(30),
            x="disease",
            y="log2fc",
            title="Top depleted diseases (log2FC), up to 30 shown",
            hover_data=["q_value", "mean_Healthy", "mean_disease", "prev_Healthy", "prev_disease", "n_Healthy", "n_disease"],
        )
        fig_d.update_layout(xaxis_title="Disease", yaxis_title="log2FC (disease vs Healthy)")
        st.plotly_chart(fig_d, use_container_width=True)

        st.download_button(
            "Download depleted diseases CSV",
            data=depleted.to_csv(index=False).encode("utf-8"),
            file_name=f"{taxon}_depleted_vs_Healthy.csv".replace(" ", "_"),
            mime="text/csv",
            key="taxonpage_dl_depleted",
        )

    # Always show raw rows for this taxon (useful even if thresholds are applied)
    st.divider()
    st.subheader("Raw per-disease results for this taxon")
    raw_tax = stats_long[stats_long["taxon"].astype(str) == str(taxon)].copy()
    raw_tax = raw_tax.sort_values(["q_value", "p_value"], ascending=[True, True], na_position="last")
    st.dataframe(raw_tax, use_container_width=True)

    st.download_button(
        "Download raw per-disease results (this taxon)",
        data=raw_tax.to_csv(index=False).encode("utf-8"),
        file_name=f"{taxon}_all_diseases_vs_Healthy.csv".replace(" ", "_"),
        mime="text/csv",
        key="taxonpage_dl_raw",
    )


def page_pairwise_group_comparison(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> None:
    st.header("Pairwise Group Comparison")

    st.markdown(
        """
Compare two groups (for example Healthy vs a disease) and identify taxa that differ.

Steps:
1) Apply optional filters.
2) Choose a taxonomic rank level.
3) Pick Group A and Group B.
4) Click "Run pairwise comparison" to display results.
        """
    )

    st.divider()

    filters = collect_sample_filters(samples)
    joined = get_filtered_abundance(samples, abund, taxa, filters)
    if joined.empty:
        st.warning("No rows after filtering. Try loosening filters.")
        return

    group_col = get_group_col(joined)
    if group_col is None:
        st.error("Could not find 'phenotype' or 'disease' after filtering.")
        st.stop()

    joined_ranked, rank_level, msg = filter_rank_level(joined, key="rank_level_pairwise")
    if msg:
        st.caption(msg)

    groups = sorted(joined_ranked[group_col].dropna().astype(str).unique().tolist())
    if len(groups) < 2:
        st.error("Not enough groups to compare.")
        st.stop()

    default_a = "Healthy" if "Healthy" in groups else groups[0]
    c1, c2 = st.columns(2)
    with c1:
        group_a = st.selectbox(
            "Group A",
            groups,
            index=groups.index(default_a) if default_a in groups else 0,
            key="pair_group_a",
        )
    with c2:
        b_candidates = [g for g in groups if g != group_a]
        group_b = st.selectbox("Group B", b_candidates, index=0, key="pair_group_b")

    st.caption("Test: Mann-Whitney U per taxon, BH-FDR for q-values.")

    min_prev = st.slider("Minimum prevalence in either group", 0.0, 1.0, 0.1, 0.05, key="pair_min_prev")
    top_k = st.slider("Number of taxa to display", 5, 50, 20, 5, key="pair_top_k")
    q_cut = st.slider("Significance threshold (q)", 0.0, 0.25, 0.05, 0.01, key="pair_q_cut")

    if st.button("Run pairwise comparison", type="primary", key="pair_run"):
        res = compute_group_comparison_vectorized(
            df=joined_ranked,
            group_col=group_col,
            group_a=group_a,
            group_b=group_b,
            abundance_col="relative_abundance",
            taxon_col="scientific_name",
            min_prevalence=float(min_prev),
        )

        if res.empty:
            st.warning("No taxa passed filters or insufficient data.")
            st.stop()

        res2 = res.copy()
        res2["abs_log2fc"] = res2["log2fc"].abs()
        sig = res2[pd.to_numeric(res2["qvalue"], errors="coerce") <= q_cut]

        show = (
            sig.sort_values("abs_log2fc", ascending=False).head(top_k)
            if len(sig) > 0
            else res2.sort_values("abs_log2fc", ascending=False).head(top_k)
        ).sort_values("log2fc")

        st.subheader("Top changing taxa")
        fig = px.bar(show, x="scientific_name", y="log2fc", title=f"Log2 fold change: {group_b} vs {group_a}")
        fig.update_layout(xaxis_title="Taxon", yaxis_title="log2 fold change")
        st.plotly_chart(fig, use_container_width=True)

        st.subheader("Volcano plot")
        volc = res2.copy()
        qv = pd.to_numeric(volc["qvalue"], errors="coerce").fillna(1.0).to_numpy()
        volc["neglog10_q"] = -np.log10(np.clip(qv, 1e-300, 1.0))
        fig2 = px.scatter(volc, x="log2fc", y="neglog10_q", hover_data=["scientific_name", "pvalue", "qvalue"])
        fig2.update_layout(xaxis_title="log2 fold change", yaxis_title="-log10(q)")
        st.plotly_chart(fig2, use_container_width=True)

        st.subheader("Results table")
        st.dataframe(res, use_container_width=True)

        csv_bytes = res.to_csv(index=False).encode("utf-8")
        st.download_button(
            "Download results as CSV",
            data=csv_bytes,
            file_name=f"group_comparison_{group_a}_vs_{group_b}.csv".replace(" ", "_"),
            mime="text/csv",
            key="pair_dl_csv",
        )
    else:
        st.info('Select groups and click "Run pairwise comparison" to display charts and results.')


