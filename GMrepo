@st.cache_data(show_spinner=False)
def join_abundance_with_names(abund: pd.DataFrame, taxa: pd.DataFrame) -> pd.DataFrame:
    a = abund.copy()
    t = taxa.copy()

    a["ncbi_taxon_id"] = a.get("ncbi_taxon_id", "").astype(str)
    t["ncbi_taxon_id"] = t.get("ncbi_taxon_id", "").astype(str)

    if "scientific_name" not in t.columns:
        for alt in ["name", "taxon_name"]:
            if alt in t.columns:
                t = t.rename(columns={alt: "scientific_name"})
                break

    if "scientific_name" not in t.columns:
        t["scientific_name"] = "Unknown"

    merged = a.merge(
        t[["ncbi_taxon_id", "scientific_name"]].drop_duplicates(),
        on="ncbi_taxon_id",
        how="left",
    )
    merged["scientific_name"] = merged["scientific_name"].fillna("Unknown")
    return merged


@st.cache_data(show_spinner=False)
def join_abundance_with_samples(
    abund_named: pd.DataFrame,
    samples: pd.DataFrame,
    abund_key: str = "accession_id",
    sample_key: str = "run_id",
) -> pd.DataFrame:
    a = abund_named.copy()
    s = samples.copy()

    if abund_key not in a.columns:
        raise ValueError(f"abundance table must contain '{abund_key}'")
    if sample_key not in s.columns:
        raise ValueError(f"sample metadata must contain '{sample_key}'")

    a[abund_key] = a[abund_key].astype(str)
    s[sample_key] = s[sample_key].astype(str)

    merged = a.merge(
        s,
        left_on=abund_key,
        right_on=sample_key,
        how="left",
        suffixes=("", "_sample"),
    )
    return merged


def get_group_col(joined: pd.DataFrame) -> Optional[str]:
    if "phenotype" in joined.columns:
        return "phenotype"
    if "disease" in joined.columns:
        return "disease"
    return None


# BIG SPEEDUP: cache the full joined table
@st.cache_data(show_spinner=False)
def build_joined(samples: pd.DataFrame, abund: pd.DataFrame, taxa: pd.DataFrame) -> pd.DataFrame:
    abund_named = join_abundance_with_names(abund, taxa)
    joined = join_abundance_with_samples(abund_named, samples, abund_key="accession_id", sample_key="run_id")
    return joined


def filter_rank_level(joined: pd.DataFrame) -> Tuple[pd.DataFrame, Optional[str], Optional[str]]:
    if "taxon_rank_level" in joined.columns and joined["taxon_rank_level"].notna().any():
        rank_levels = sorted(joined["taxon_rank_level"].dropna().unique().tolist())
        rank_level = st.selectbox("Taxon rank level", rank_levels, index=0)
        return joined[joined["taxon_rank_level"].astype(str) == str(rank_level)].copy(), rank_level, None
    return joined.copy(), None, "No taxon_rank_level found. Using all rows."


def apply_optional_filters(joined: pd.DataFrame) -> pd.DataFrame:
    with st.expander("Optional filters"):
        if "experiment_type" in joined.columns and joined["experiment_type"].notna().any():
            exp_types = ["All"] + sorted(joined["experiment_type"].dropna().unique().tolist())
            exp_choice = st.selectbox("Experiment type", exp_types)
            if exp_choice != "All":
                joined = joined[joined["experiment_type"] == exp_choice]
        else:
            st.caption("No experiment_type column available (or all empty).")

        if "country" in joined.columns and joined["country"].notna().any():
            countries = ["All"] + sorted(joined["country"].dropna().unique().tolist())
            country = st.selectbox("Country", countries)
            if country != "All":
                joined = joined[joined["country"] == country]
        else:
            st.caption("No country column available (or all empty).")

        if "recent_antibiotics_use" in joined.columns and joined["recent_antibiotics_use"].notna().any():
            abx = st.selectbox("Recent antibiotics use", ["All", "Y", "N"])
            if abx != "All":
                joined = joined[joined["recent_antibiotics_use"] == abx]
        else:
            st.caption("No recent_antibiotics_use column available (or all empty).")

    return joined


